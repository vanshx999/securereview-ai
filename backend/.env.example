# ===========================================
# SecureReview AI — Environment Configuration
# ===========================================
# Copy this to .env and fill in your values

# --- Application ---
APP_NAME=SecureReview AI
APP_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true

# --- Database ---
# SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./securereview.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://securereview:securereview_dev@localhost:5432/securereview
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-secure-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Encryption (Fernet AES-256) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- LLM Providers (ordered by priority: groq -> ollama -> openai -> anthropic) ---
GROQ_API_KEY=gsk_your_groq_api_key_here  # Free tier: llama-3.1-70b-versatile
OLLAMA_URL=http://localhost:11434  # Optional local fallback
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub App (for PR integration) ---
GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret
GITHUB_WEBHOOK_SECRET=a-random-string-for-hmac-verification
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...
GITHUB_INSTALLATION_URL=https://github.com/apps/your-app-name/installations/new

# --- GitLab (optional) ---
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_WEBHOOK_SECRET=

# --- Notifications ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=

# --- Stripe (for billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Data Retention ---
DATA_RETENTION_DAYS=7
FINDING_RETENTION_DAYS=365
